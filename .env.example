# FeedMe — environment configuration
# Copy to .env and fill in values:  cp .env.example .env

# ============================================================
# Server
# ============================================================
PORT=8002
NODE_ENV=development
LOG_LEVEL=info

# ============================================================
# LLM — Azure OpenAI GPT-5.5 (primary for all 3 agents + MemGC)
# Reference: /Users/carrickcheah/Project/root_ai/z_API/API/AZURE_5-5.md
# ============================================================
AZURE_OPENAI_API_KEY=                          # <-- paste from AZURE_5-5.md
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.5
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_MODEL=gpt-5.5

# Per-agent reasoning_effort ("none" | "low" | "medium" | "high")
# GPT-5.5 supports reasoning effort similar to o1/o3 family. Start with "none"
# (no extra reasoning tokens) and bump up if response quality is too shallow.
AZURE_REASONING_CUSTOMER_FACING=none
AZURE_REASONING_KITCHEN=none
AZURE_REASONING_INVENTORY=none

# ============================================================
# Infrastructure (docker-compose services)
# ============================================================
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094
MEMGC_URL=http://localhost:8003

# Kafka topic names
KAFKA_TOPIC_ORDER_CREATED=order.created
KAFKA_TOPIC_ORDER_UPDATED=order.updated
KAFKA_TOPIC_INGREDIENT_CONSUMED=ingredient.consumed
KAFKA_TOPIC_STOCK_LOW=stock.low
KAFKA_TOPIC_TICKET_READY=ticket.ready

# ============================================================
# MCP server URLs (run via `bun run mcp:all` locally)
# ============================================================
MCP_POS_URL=http://localhost:4001/mcp
MCP_KITCHEN_DISPLAY_URL=http://localhost:4002/mcp
MCP_PAYMENT_URL=http://localhost:4003/mcp
MCP_SUPPLIER_URL=http://localhost:4004/mcp

# ============================================================
# Data — SQLite (single tenant, single directory)
# ============================================================
DATA_DIR=./data

# ============================================================
# Restaurant config (single tenant)
# ============================================================
RESTAURANT_NAME=IceYoo Desaru
RESTAURANT_TIMEZONE=Asia/Kuala_Lumpur
RESTAURANT_CURRENCY=MYR
RESTAURANT_CURRENCY_SYMBOL=RM
# SST disabled for prototype
SST_PERCENT=0

# ============================================================
# Frontend — existing snow-dessert app
# ============================================================
FRONTEND_DIR=./snow-dessert
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ============================================================
# Observability — Langfuse (Phase 3)
# ============================================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================================
# Internal service auth (Phase 4)
# ============================================================
INTERNAL_SERVICE_SECRET=change-me-in-production
