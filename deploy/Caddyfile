# Caddy — reverse proxy + auto Let's Encrypt SSL for FeedMe.
#
# Caddy fetches the cert automatically via ACME HTTP-01 the first time the
# domain resolves to this VM. Renewals are automatic (60-day cycle).
#
# Routes:
#   /api/*  → main app container (Bun) on port 8002
#   /*      → static snow-dessert/ frontend
#
# Note: /api/chat is SSE (Server-Sent Events). reverse_proxy handles streaming
# natively — no extra config needed. Caddy disables buffering for SSE.

feedm.carrickcheah.com {
  # Strong defaults
  encode gzip zstd

  # API → main app
  handle /api/* {
    reverse_proxy app:8002 {
      # SSE: no response buffering, longer write timeout
      flush_interval -1
      transport http {
        response_header_timeout 5m
      }
    }
  }

  # Top-level /health → main app (app exposes /health, not /api/health).
  # /ready follows same pattern. Without this, Caddy routes /health to the
  # static handler and returns the frontend index.html (200 but wrong body).
  handle /health {
    reverse_proxy app:8002
  }
  handle /ready {
    reverse_proxy app:8002
  }

  # Static frontend
  handle {
    root * /srv/snow-dessert
    try_files {path} /index.html
    file_server
  }

  # Security + cache headers
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    -Server
    # Force revalidate every request — prototype frontend is small
    # and changes often; serving stale UI after a deploy is the most
    # painful demo bug.
    Cache-Control "no-cache, no-store, must-revalidate"
    Pragma "no-cache"
    Expires "0"
  }

  log {
    output stdout
    format console
    level INFO
  }
}

# Optional: redirect bare apex / www to the canonical host
# (skip if you don't own those records yet)
